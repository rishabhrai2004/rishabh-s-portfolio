# NVIDIA API Configuration
# To enable the AI-powered chatbot:
# 1. Create an NVIDIA API key
# 2. Paste the key below
# 3. Set the model ID used for chat completion
# 4. Optionally provide a comma-separated fallback model list

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=NVIDIABuild-Autogen-82
NVIDIA_MODELS=NVIDIABuild-Autogen-82,meta/llama-3.1-70b-instruct,mistralai/mixtral-8x7b-instruct-v0.1
